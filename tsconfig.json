{
  "compilerOptions": {
    "target": "es2020",
    "module": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "types": ["node"]
  },
  "include": ["./src"],
  "exclude": ["node_modules", "dist"]
}
