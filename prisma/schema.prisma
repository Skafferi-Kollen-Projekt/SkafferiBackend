generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StorageLocation {
  KYL
  FRYS
  SKAFFERI
}

enum AmountStatus {
  EMPTY // ! Helt slut
  LOW // ! Lite kvar räcker inte till alla
  MEDIUM // ! Lagom, kan räcka men strikt
  HIGH // ! Fullt, Räcker gott och väl
}

enum Role {
  USER
  ADMIN
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  firstname  String
  lastname   String
  password   String
  role       Role      @default(USER)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  products   Product[]
}

model Product {
  id           Int             @id @default(autoincrement())
  name         String
  quantity     Float           @default(1)
  unit         String // ? t.ex "st", "g", "ml"
  amountStatus AmountStatus    @default(HIGH)
  expiryDate   DateTime?
  location     StorageLocation @default(SKAFFERI)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  icon     String?
  products Product[]
}
